# Scraping
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=6.0
BROWSER_HEADLESS=true
LOG_LEVEL=INFO

# Portale
PRACUJ_BASE_URL=https://www.pracuj.pl/praca
ROCKETJOBS_BASE_URL=https://rocketjobs.pl/oferty-pracy

# HubSpot CRM — Private App
# Utwórz na: https://app.hubspot.com/private-apps → "Create private app"
# Wymagane scopes: crm.objects.companies.read, crm.objects.companies.write,
#                  crm.objects.deals.read, crm.objects.notes.read,
#                  crm.objects.calls.read, crm.objects.emails.read
HUBSPOT_ACCESS_TOKEN=pat-xx-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_PORTAL_ID=12345678

# OpenAI API — generator emaili i podsumowań
# Klucz z: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxx
